<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{title}}</title>
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap'
      rel='stylesheet'
    />
  </head>
  <body
    style="margin: 0; padding: 0; background-color: #F9F7F4; font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; -webkit-font-smoothing: antialiased;"
  >

    <table
      width='100%'
      cellpadding='0'
      cellspacing='0'
      style='background-color: #F9F7F4; padding: 40px 16px;'
    >
      <tr>
        <td align='center'>
          <table
            width='100%'
            cellpadding='0'
            cellspacing='0'
            style='max-width: 560px;'
          >

            {{! Branding }}
            <tr>
              <td style='padding-bottom: 24px;'>
                {{> logo}}
              </td>
            </tr>

            {{! Card }}
            <tr>
              <td
                style='background-color: #FFFFFF; border-radius: 10px; border: 1px solid #E6E3DE; padding: 32px;'
              >
                {{{body}}}
              </td>
            </tr>

            {{! Footer }}
            <tr>
              <td
                style='padding-top: 24px; font-size: 12px; color: #6B6878; text-align: center; line-height: 1.6;'
              >
                If you did not request this, please ignore this email.<br />
                &copy;
                {{year}}
                Tokenizer. All rights reserved.
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>

  </body>
</html>